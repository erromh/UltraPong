	$(CMAKE_COMMAND) -E cmake_progress_start /home/errom/projects/myprojects/UltraPong/build/CMakeFiles 70
	$(MAKE) $(MAKESILENT) -f CMakeFiles/Makefile2 src/Ball/CMakeFiles/Ball.dir/all
	$(CMAKE_COMMAND) -E cmake_progress_start /home/errom/projects/myprojects/UltraPong/build/CMakeFiles 0
.PHONY : src/Ball/CMakeFiles/Ball.dir/rule

# Convenience name for target.
Ball: src/Ball/CMakeFiles/Ball.dir/rule
.PHONY : Ball

# clean rule for target.
src/Ball/CMakeFiles/Ball.dir/clean:
	$(MAKE) $(MAKESILENT) -f src/Ball/CMakeFiles/Ball.dir/build.make src/Ball/CMakeFiles/Ball.dir/clean
.PHONY : src/Ball/CMakeFiles/Ball.dir/clean

#=============================================================================
# Special targets to cleanup operation of make.

# Special rule to run CMake to check the build system integrity.
# No rule that depends on this can have commands that come from listfiles
# because they might be regenerated.
cmake_check_build_system:
	$(CMAKE_COMMAND) -S$(CMAKE_SOURCE_DIR) -B$(CMAKE_BINARY_DIR) --check-build-system CMakeFiles/Makefile.cmake 0
.PHONY : cmake_check_build_system

